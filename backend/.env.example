# CloudPi Configuration
# Copy this file to .env and fill in values

# JWT secret for token signing (change this in production!)
JWT_SECRET=cloudpi-secret-key-change-this-in-production

# Server port
PORT=3001

# ── Encryption Key ─────────────────────────────────────────────────
# 256-bit hex key used for:
#   - AES-256-GCM file encryption (application-level, replaces LUKS)
#   - HMAC drive identity signatures
#   - SMTP password encryption
# Generate with: openssl rand -hex 32
# CLOUDPI_ENCRYPTION_KEY=

# ── Drive Event Webhook ────────────────────────────────────────────
# Shared secret for authenticating udev webhook calls.
# Must match the secret generated by harden-usb-mounts.sh
# (stored at /etc/cloudpi/udev-secret on the Pi).
# Generate with: openssl rand -hex 32
# CLOUDPI_UDEV_SECRET=
