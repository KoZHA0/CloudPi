# CloudPi Configuration
# Copy this file to .env and fill in values

# JWT secret for token signing (change this in production!)
JWT_SECRET=cloudpi-secret-key-change-this-in-production

# Server port
PORT=3001

# ── LUKS Configuration ──────────────────────────────────────────────
# These are only used if you manage LUKS unlock from within Node.js.
# If you unlock LUKS at the host OS level (systemd / boot script),
# only LUKS_MOUNT_POINT matters — the backend just checks if it's mounted.
#
# LUKS_DEVICE=/dev/sda1
# LUKS_MAPPER_NAME=cloudpi-data
# LUKS_MOUNT_POINT=/media/cloudpi-data

# ── Encryption Key ─────────────────────────────────────────────────
# 64-character hex string used for HMAC drive identity signatures
# and SMTP password encryption. Generate with: openssl rand -hex 32
# CLOUDPI_ENCRYPTION_KEY=

# ── Drive Event Webhook ────────────────────────────────────────────
# Shared secret for authenticating udev webhook calls.
# Must match the secret generated by harden-usb-mounts.sh
# (stored at /etc/cloudpi/udev-secret on the Pi).
# Generate with: openssl rand -hex 32
# CLOUDPI_UDEV_SECRET=
