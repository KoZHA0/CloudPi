# CloudPi Configuration
# Copy this file to .env and fill in values

# JWT secret for token signing (change this in production!)
JWT_SECRET=cloudpi-secret-key-change-this-in-production

# Server port
PORT=3001

# ── LUKS Configuration ──────────────────────────────────────────────
# These are only used if you manage LUKS unlock from within Node.js.
# If you unlock LUKS at the host OS level (systemd / boot script),
# only LUKS_MOUNT_POINT matters — the backend just checks if it's mounted.
#
# LUKS_DEVICE=/dev/sda1
# LUKS_MAPPER_NAME=cloudpi-data
# LUKS_MOUNT_POINT=/media/cloudpi-data
