# Dependencies (will be installed fresh in container)
node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs (will be built in container)
frontend/dist/

# Git
.git
.gitignore

# Environment files (passed via docker-compose)
.env
backend/.env
.env.local

# Database (persisted via volumes)
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.db.sqbpro

# User uploads and storage (persisted via volumes)
backend/uploads/
backend/storage/
.cloudpi-id

# Local Docker volumes
docker-data/

# IDE/Editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Documentation and walkthroughs
docs/
backend/walkthroughs/
*.md
*.PNG
*.png

# Deploy scripts (not needed in container)
deploy/

# Tests
backend/tests/
coverage/

# Logs
*.log
logs/
