# CloudPi Configuration
# Copy this file to .env and fill in values

# JWT secret for token signing (change this in production!)
JWT_SECRET=cloudpi-secret-key-change-this-in-production

# AES-256 encryption key (64 hex characters = 32 bytes)
# If left empty, a random key will be auto-generated on first run
# WARNING: If you lose this key, all encrypted files become unrecoverable!
CLOUDPI_ENCRYPTION_KEY=

# Server port
PORT=3001
